#!/bin/bash
# Palette launcher — opens Palette in a standalone native window (no browser).
# The project folder is detected automatically from this app's location
# (<project>/Palette.app/Contents/MacOS/Palette), so it works wherever the
# Palette folder lives — no path editing needed. Keep Palette.app inside the
# Palette folder; to pin it, use the Dock's "Keep in Dock" option.

DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT="$(cd "$DIR/../../.." && pwd)"
PY="$PROJECT/.venv/bin/python"

if [ ! -x "$PY" ]; then
  osascript -e 'display dialog "Palette is not set up yet. Open the Palette folder in Finder and double-click setup.command first, then open Palette again." buttons {"OK"} default button "OK" with title "Palette" with icon caution' >/dev/null 2>&1
  exit 1
fi

# On Apple Silicon, macOS may otherwise launch this app under x86_64 (Rosetta),
# which can't load the arm64 packages that setup.command installed. Force the
# Mac's native architecture so the runtime matches the installed packages.
if [ "$(sysctl -n hw.optional.arm64 2>/dev/null)" = "1" ]; then
  exec arch -arm64 "$PY" "$PROJECT/desktop.py"
fi

exec "$PY" "$PROJECT/desktop.py"
